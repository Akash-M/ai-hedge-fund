# ============================================================================
# AI Hedge Fund -> eToro live bridge configuration
# Copy to .env (or set these as host/CI secrets). NEVER commit real keys.
# ============================================================================

# --- eToro API (get keys at https://www.etoro.com/settings/trade) ---
ETORO_API_KEY=your-etoro-api-key
ETORO_USER_KEY=your-etoro-user-key
ETORO_ENVIRONMENT=demo            # demo (paper) | real  -- START ON DEMO

# --- Market data for the agents (https://financialdatasets.ai/) ---
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# --- LLM providers (set keys for any you want; failover uses whatever is present) ---
# Primary provider/model:
AIHF_LLM_MODEL=gpt-4.1-mini       # cost-effective default
AIHF_LLM_PROVIDER=OpenAI          # OpenAI | Google | Anthropic | Groq | DeepSeek | ...
OPENAI_API_KEY=your-openai-api-key
# Fallbacks (free tiers: Google + Groq; Groq has the highest free rate limits):
GROQ_API_KEY=your-groq-api-key            # free tier, high limits, fast
GOOGLE_API_KEY=your-google-gemini-api-key # free tier (ai.dev)
ANTHROPIC_API_KEY=your-anthropic-api-key  # paid (no perpetual free tier)
DEEPSEEK_API_KEY=your-deepseek-api-key
# Failover order on rate-limit/quota errors. Empty = auto-build from keys present.
# Example: "OpenAI:gpt-4.1-mini,Groq:llama-3.3-70b-versatile,Google:gemini-2.5-flash"
AIHF_LLM_FALLBACKS=
AIHF_LLM_COOLDOWN_S=90            # bench a provider this long after it rate-limits

# --- Capital & universe ---
AIHF_BUDGET_USD=1000              # how much the bot manages (0 = whole account)
AIHF_TICKERS=NVDA,MSFT,AAPL,GOOGL,AMZN,META,TSLA,AMD,AVGO,CRM,NFLX,QQQ

# --- Risk profile (aggressive) + HARD guardrails (override any preset) ---
AIHF_RISK_PROFILE=aggressive
AIHF_MAX_POSITION_PCT=0.25        # max % of budget in one name
AIHF_MAX_POSITIONS=6              # max concurrent names
AIHF_MAX_INVESTED_PCT=1.00        # max % of budget deployed at once
AIHF_MIN_ORDER_USD=50             # eToro stock minimum is ~$50
AIHF_STOP_LOSS_PCT=0.30           # attach a 30% stop to each long (0 = none)
AIHF_MIN_CONFIDENCE=45            # ignore buy signals below this confidence
AIHF_ALLOW_SHORT=false            # long-only by default (shorting = CFD/leverage)
AIHF_LEVERAGE=1                   # keep at 1 (no leverage)
AIHF_LOOKBACK_MONTHS=6            # price history window for volatility/correlation

# --- Operations ---
AIHF_DRY_RUN=true                 # true = compute & log orders but DO NOT send
# AIHF_CONFIRM_LIVE=I_UNDERSTAND  # REQUIRED to trade real money (real + dry_run=false)
AIHF_STATE_DIR=./live_state
AIHF_NOTIFY_WEBHOOK=              # optional Slack/Discord/webhook URL for summaries
AIHF_LOG_LEVEL=INFO
